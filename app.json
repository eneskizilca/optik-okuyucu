{
  "expo": {
    "name": "Optik Okuyucu",
    "slug": "optik-okuyucu",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/eroz-icon.png",
    "scheme": "optikokuyucu",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Optik formları taramak için kamera erişimi gereklidir.",
        "NSPhotoLibraryUsageDescription": "Galeriden optik form görüntüsü seçmek için erişim gereklidir."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/images/eroz-icon.png"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ],
      "package": "com.optikokuyucu.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/eroz-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/eroz-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF",
          "dark": {
            "backgroundColor": "#FFFFFF"
          }
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Optik formları taramak için kamera erişimi gereklidir."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Galeriden optik form seçmek için erişim gereklidir."
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "Optik formları taramak için kamera erişimi gereklidir."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "3ffcff1f-7a86-4125-b87e-c4f6837dbec3"
      }
    }
  }
}
